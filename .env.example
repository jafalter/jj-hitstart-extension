# Copy to .env (which is git-ignored) and fill in.
# EDITION_KEY encrypts the committed songlist (/editions/*.enc).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# KEEP A COPY IN YOUR PASSWORD MANAGER. If lost, past editions cannot be decrypted
# for future exclusion.
EDITION_KEY=

# Name used for this edition's encrypted songlist file (/editions/<EDITION_NAME>.enc)
EDITION_NAME=edition-01
